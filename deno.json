{
  "tasks": {
    "build": "npm ci && npm run build",
    "serve": "deno run --allow-net --allow-read serve.ts",
    "start": "deno task build && deno task serve"
  },
  "imports": {
    "@std/http": "jsr:@std/http@^1"
  },
  "deploy": {
    "install": "npm ci",
    "build": "npm run build",
    "runtime": {
      "type": "dynamic",
      "entrypoint": "serve.ts"
    }
  }
}
